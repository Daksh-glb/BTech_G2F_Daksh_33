#include <stdio.h>

int main() {
    float a, b, c;

    printf("Enter three sides: ");
    scanf("%f %f %f", &a, &b, &c);

    if (a + b > c && a + c > b && b + c > a) {
        printf("Valid triangle\n");

        if (a == b && b == c)
            printf("Equilateral triangle");
        else if (a == b || b == c || a == c)
            printf("Isosceles triangle");
        else
            printf("Scalene triangle");
    } else {
        printf("Not a valid triangle");
    }

    return 0;
}
